# PyLabRobot Runner — copy to .env and fill in your values

# Google AI API key (from https://aistudio.google.com/apikey)
# Either name works:
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Or use Vertex AI instead (leave GOOGLE_API_KEY empty):
# VERTEX_PROJECT=my-gcp-project
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.0-flash
